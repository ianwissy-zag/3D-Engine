# --- Ignore Vivado Temp Files ---
*.log
*.jou
*.str
.Xil/
*.os
*.obj

# --- Ignore Junk Folders ---
# Use **/ to ensure it finds the folder regardless of where it is in the tree
**/final.cache/
**/final.hw/
**/final.sim/
**/final.ip_user_files/

# Runs
**/final.runs/**/*
!**/final.runs/**/
!**/final.runs/**/*.bit
!**/final.runs/**/*.ltx

# --- Source Files ---
!*.xpr
!**/final.srcs/**